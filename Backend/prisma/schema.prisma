generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String      @id @default(uuid())
  email     String   @unique
  username  String  @unique
  password  String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  posts     Post[]

  @@map("users")
}

model Post {
  id        String      @id @default(uuid())
  authorId  String
  personId  String?

  title     String
  hometown  String // Quê quán của thân nhân
  location  String // Nơi ở hiện tại của thân nhân
  description    String // Mô tả chi tiết về thân nhân, có thể bao gồm các đặc điểm nhận dạng, v.v.
  lost_year Int // Năm mất tích của thân nhân
  status    String   @default("PENDING") // Trạng thái của bài đăng PENDING, CONFIRMED, REJECTED
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@index([personId])
  
  @@map("posts")
}